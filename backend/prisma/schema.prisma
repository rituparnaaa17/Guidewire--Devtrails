// ─────────────────────────────────────────────────────────────────────────────
// ShieldPay KAVACH — Prisma Schema
// Source of truth. Run: npx prisma db push
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────────────────────

enum RiskLevel {
  low
  medium
  high
  very_high
}

enum WorkType {
  construction
  factory
  agriculture
  delivery
  retail
  domestic
  other
}

enum PlanTier {
  basic
  standard
  premium
}

enum PolicyStatus {
  active
  expired
  cancelled
}

enum TriggerType {
  HEAVY_RAIN
  FLOOD
  SEVERE_AQI
  HEATWAVE
  ZONE_SHUTDOWN
}

enum TriggerStatus {
  active
  resolved
}

enum ClaimStatus {
  pending
  approved
  under_review
  soft_verification
  rejected
  paid
  blocked
}

enum FraudSeverity {
  low
  medium
  high
  critical
}

// ── MODELS ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  phone         String    @unique @db.VarChar(15)
  name          String?   @db.VarChar(120)
  aadhaarLast4  String?   @db.VarChar(4)
  upiId         String?   @db.VarChar(120)
  platforms     String[]
  city          String?   @db.VarChar(100)
  zone          String?   @db.VarChar(100)
  weeklyIncome  Decimal?  @db.Decimal(10, 2)
  workingHours  Decimal?  @db.Decimal(4, 1)
  shiftStart    String?   @db.VarChar(5)
  shiftEnd      String?   @db.VarChar(5)
  workingDays   String[]
  consentGPS    Boolean   @default(false)
  consentPayment Boolean  @default(false)
  consentPlatform Boolean @default(false)
  onboardingDone Boolean  @default(false)
  // Live GPS tracking
  currentLat    Float?
  currentLon    Float?
  registeredLat Float?
  registeredLon Float?
  lastLocationAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workerProfile  WorkerProfile?
  userSettings   UserSettings?
  policies       Policy[]
  claims         Claim[]
  pricingQuotes  PricingQuote[]

  @@map("users")
}

model WorkerProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @db.Uuid
  workType           WorkType @default(delivery)
  yearsExperience    Int      @default(0)
  avgWeeklyIncome    Decimal  @db.Decimal(10, 2)
  dailyHours         Int
  weeklyActiveHours  Int      @default(42)
  preferredWorkStart String?  @db.VarChar(5)
  preferredWorkEnd   String?  @db.VarChar(5)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("worker_profiles")
}

model UserSettings {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  connectedPlatform String?  @db.VarChar(60)
  activePlan        String?  @db.VarChar(120)
  autoRenewal       String   @default("Enabled") @db.VarChar(20)
  primaryUpiId      String?  @db.VarChar(120)
  backupBankAccount String?  @db.VarChar(120)
  payoutFrequency   String   @default("Not set") @db.VarChar(40)
  weatherWarnings   String   @default("SMS Only") @db.VarChar(60)
  claimUpdates      String   @default("SMS Only") @db.VarChar(60)
  weeklySummary     String   @default("Email Only") @db.VarChar(60)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Zone {
  id          String    @id @default(uuid()) @db.Uuid
  zoneName    String    @unique @db.VarChar(100)
  zoneCode    String    @unique @db.VarChar(20)
  city        String    @db.VarChar(100)
  state       String    @db.VarChar(100)
  riskLevel   RiskLevel
  riskFactor  Decimal   @db.Decimal(4, 3)
  basePremium Decimal   @db.Decimal(10, 2)
  // Geographic center for live GPS matching
  centerLat   Float?
  centerLon   Float?
  radiusKm    Float     @default(5.0)
  createdAt   DateTime  @default(now())

  pincodeZoneMaps  PincodeZoneMap[]
  pricingQuotes    PricingQuote[]
  triggerEvents    TriggerEvent[]
  weatherSnapshots WeatherSnapshot[]
  aqiSnapshots     AqiSnapshot[]

  @@map("zones")
}

model PincodeZoneMap {
  id        String   @id @default(uuid()) @db.Uuid
  pincode   String   @unique @db.VarChar(10)
  zoneId    String   @db.Uuid
  city      String?  @db.VarChar(100)
  createdAt DateTime @default(now())

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("pincode_zone_map")
}

model PricingQuote {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String?  @db.Uuid
  zoneId           String   @db.Uuid
  city             String   @db.VarChar(100)
  pincode          String?  @db.VarChar(10)
  workType         String   @db.VarChar(60)
  dailyHours       Int
  avgWeeklyIncome  Decimal  @db.Decimal(10, 2)
  planTier         PlanTier
  basePremium      Decimal  @db.Decimal(10, 2)
  locRiskSurcharge Decimal  @db.Decimal(10, 2)
  workerExpFactor  Decimal  @db.Decimal(10, 2)
  planSurcharge    Decimal  @db.Decimal(10, 2)
  discountApplied  Decimal  @default(0) @db.Decimal(10, 2)
  finalPremium     Decimal  @db.Decimal(10, 2)
  coverageAmount   Decimal  @db.Decimal(12, 2)
  riskBand         String   @db.VarChar(20)
  expiresAt        DateTime @default(dbgenerated("NOW() + INTERVAL '24 hours'"))
  createdAt        DateTime @default(now())

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  zone     Zone     @relation(fields: [zoneId], references: [id])
  policies Policy[]

  @@map("pricing_quotes")
}

model Policy {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String       @db.Uuid
  quoteId          String       @db.Uuid
  policyNumber     String       @unique @db.VarChar(30)
  planTier         PlanTier
  status           PolicyStatus @default(active)
  finalPremium     Decimal      @db.Decimal(10, 2)
  coverageAmount   Decimal      @db.Decimal(12, 2)
  coverageTriggers String[]
  validFrom        DateTime     @default(now())
  validUntil       DateTime     @default(dbgenerated("NOW() + INTERVAL '7 days'"))
  // Razorpay
  razorpayOrderId   String?     @db.VarChar(100)
  razorpayPaymentId String?     @db.VarChar(100)
  paymentStatus     String      @default("pending") @db.VarChar(20)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote  PricingQuote @relation(fields: [quoteId], references: [id])
  claims Claim[]

  @@map("policies")
}

model TriggerEvent {
  id          String        @id @default(uuid()) @db.Uuid
  zoneId      String        @db.Uuid
  triggerType TriggerType
  severity    Decimal       @default(0) @db.Decimal(10, 2)
  startTime   DateTime      @default(now())
  endTime     DateTime?
  status      TriggerStatus @default(active)
  source      String        @db.VarChar(120)
  rawPayload  Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  zone   Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  claims Claim[]

  @@map("trigger_events")
}

model Claim {
  id                  String      @id @default(uuid()) @db.Uuid
  userId              String      @db.Uuid
  policyId            String      @db.Uuid
  triggerEventId      String      @db.Uuid
  claimStatus         ClaimStatus @default(pending)
  estimatedIncomeLoss Decimal     @default(0) @db.Decimal(12, 2)
  actualEarned        Decimal     @default(0) @db.Decimal(12, 2)
  netLoss             Decimal     @default(0) @db.Decimal(12, 2)
  payoutAmount        Decimal     @default(0) @db.Decimal(12, 2)
  predictedLoss       Decimal?    @db.Decimal(12, 2)
  mlConfidence        Decimal?    @db.Decimal(5, 4)
  trustScore          Decimal?    @db.Decimal(5, 2)
  fraudScore          Int?
  fraudReasons        Json        @default("[]")
  fraudProbability    Float?
  riskLevel           String?
  riskFactors         Json        @default("[]")
  // Location verification
  locationMatch       Boolean?
  locationLat         Float?
  locationLon         Float?
  locationLabel       String?
  liveVerified        Boolean     @default(false)
  triggerLevel        Int         @default(1)
  levelMultiplier     Decimal     @default(0.60) @db.Decimal(4, 2)
  coveragePercentage  Decimal     @default(80.00) @db.Decimal(5, 2)
  triggerReason       String?
  explanation         String?
  reviewReason        String?
  blockchainHash      String?     @db.VarChar(300)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy       Policy       @relation(fields: [policyId], references: [id], onDelete: Cascade)
  triggerEvent TriggerEvent @relation(fields: [triggerEventId], references: [id], onDelete: Cascade)
  fraudLogs    FraudLog[]

  @@unique([policyId, triggerEventId])
  @@map("claims")
}

model FraudLog {
  id          String        @id @default(uuid()) @db.Uuid
  // claimId is nullable: pre-claim hard blocks have no claim row yet
  claimId     String?       @db.Uuid
  // Legacy fields (kept for ML training data)
  reason      String        @default("")
  severity    FraudSeverity @default(low)
  score       Decimal       @default(0) @db.Decimal(5, 4)
  // Enforcement engine fields
  flags       Json          @default("[]")
  decision    String        @default("APPROVE") @db.VarChar(20)
  fraudScore  Int           @default(0)
  ppcsScore   Int           @default(100)
  blockReason String?       @db.Text
  createdAt   DateTime      @default(now())

  claim Claim? @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("fraud_logs")
}

model WeatherSnapshot {
  id                  String   @id @default(uuid()) @db.Uuid
  zoneId              String   @db.Uuid
  rainfallMmPerHour   Decimal  @default(0) @db.Decimal(10, 2)
  heatIndex           Decimal  @default(0) @db.Decimal(10, 2)
  weatherStatus       String   @db.VarChar(50)
  source              String   @db.VarChar(120)
  recordedAt          DateTime @default(now())
  rawPayload          Json     @default("{}")

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("weather_snapshots")
}

model AqiSnapshot {
  id         String   @id @default(uuid()) @db.Uuid
  zoneId     String   @db.Uuid
  aqi        Int
  source     String   @db.VarChar(120)
  recordedAt DateTime @default(now())
  rawPayload Json     @default("{}")

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("aqi_snapshots")
}

model OtpStore {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @db.VarChar(15)
  otp       String   @db.VarChar(6)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_store")
}
